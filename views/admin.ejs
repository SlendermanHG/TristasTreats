<%- include("partials/header", { title: "Owner Inbox" }) %>

<main class="shell dashboard">
  <aside class="sidebar-stack">
    <section class="section-card">
      <span class="eyebrow">Admin access</span>
      <h2>Add another admin</h2>
      <p class="muted">Create a new admin directly, or promote an existing customer account by email.</p>
      <form action="/admin/admin-users" method="post">
        <label>
          Name
          <input name="name" required placeholder="Manager name" />
        </label>
        <label>
          Email
          <input name="email" type="email" required placeholder="manager@example.com" />
        </label>
        <label>
          Password for new admin only
          <input name="password" type="password" placeholder="Leave blank if promoting existing user" />
        </label>
        <button class="button accent" type="submit">Save Admin Access</button>
      </form>
      <div class="thread-list">
        <% adminUsers.forEach((adminUser) => { %>
          <article class="thread">
            <div class="thread-meta">
              <strong><%= adminUser.name %></strong>
              <span class="pill">admin</span>
            </div>
            <p><%= adminUser.email %></p>
          </article>
        <% }) %>
      </div>
    </section>

    <section class="section-card">
      <span class="eyebrow">Owner inbox</span>
      <h2>Orders and questions</h2>
      <div class="thread-list">
        <% conversations.forEach((conversation) => { %>
          <a href="/admin?thread=<%= conversation.id %>">
            <article class="thread <%= selectedConversation && selectedConversation.id === conversation.id ? "active" : "" %>">
              <div class="thread-meta">
                <strong><%= conversation.subject %></strong>
                <span class="pill"><%= conversation.status %></span>
              </div>
              <p><%= conversation.customer_name %> • <%= conversation.type %></p>
              <p><%= conversation.customer_email %></p>
            </article>
          </a>
        <% }) %>
      </div>
    </section>

    <section class="section-card" id="reviews">
      <span class="eyebrow">Pending reviews</span>
      <div class="thread-list">
        <% pendingReviews.forEach((review) => { %>
          <article class="thread">
            <div class="thread-meta">
              <strong><%= review.reviewer_name %></strong>
              <span class="stars"><%= "★".repeat(review.rating) %></span>
            </div>
            <p><%= review.body %></p>
            <form action="/reviews/<%= review.id %>/approve" method="post">
              <button class="button accent" type="submit">Approve</button>
            </form>
            <form action="/reviews/<%= review.id %>/delete" method="post">
              <button class="button subtle" type="submit">Delete</button>
            </form>
          </article>
        <% }) %>
      </div>
    </section>
  </aside>

  <section class="section-card">
    <% if (selectedConversation) { %>
      <span class="eyebrow">Customer thread</span>
      <h2><%= selectedConversation.subject %></h2>
      <p class="muted"><%= selectedConversation.customer_name %> • <%= selectedConversation.customer_email %> • <%= selectedConversation.type %></p>

      <div class="stack-actions">
        <form action="/conversations/<%= selectedConversation.id %>/status" method="post">
          <input type="hidden" name="status" value="<%= selectedConversation.status === "open" ? "closed" : "open" %>" />
          <button class="button subtle" type="submit">Mark as <%= selectedConversation.status === "open" ? "closed" : "open" %></button>
        </form>
      </div>

      <div class="message-stream">
        <% selectedConversation.messages.forEach((message) => { %>
          <article class="message-bubble <%= message.sender_role === "admin" ? "admin" : "customer" %>">
            <div class="message-header">
              <strong><%= message.sender_name %> (<%= message.sender_role %>)</strong>
              <span><%= message.created_at %></span>
            </div>
            <div><%= message.body %></div>
          </article>
        <% }) %>
      </div>

      <form action="/conversations/<%= selectedConversation.id %>/reply" method="post">
        <label>
          Reply as Trista
          <textarea name="body" required placeholder="Respond directly inside this thread."></textarea>
        </label>
        <button class="button accent" type="submit">Send Reply</button>
      </form>
    <% } else { %>
      <span class="eyebrow">No thread selected</span>
      <h2>Choose a conversation</h2>
      <p class="muted">Customer order requests and questions stay here instead of mixing with a personal email inbox.</p>
    <% } %>
  </section>
</main>

<%- include("partials/footer") %>
